# 서버 포트
PORT=8080

# QR에 들어갈 base URL.
# 키오스크는 토큰 발행 시 이 URL과 토큰을 합쳐 QR을 만든다.
# 내부망 테스트 예시:
#   PUBLIC_BASE_URL=http://192.168.0.100:8080
# 운영 예시:
#   PUBLIC_BASE_URL=https://claw.example.com
PUBLIC_BASE_URL=http://192.168.0.100:8080

# 토큰 만료 시간 (초). 발행 후 이 시간 안에 사용 안 하면 무효
TOKEN_TTL_SECONDS=300

# 한 게임 세션의 최대 길이 (초)
SESSION_DURATION_SECONDS=60

# 하트비트 주기 (밀리초). 이 주기마다 ping 보내고 응답 없으면 끊김 처리
# 30000 = 30초 (60초 세션 동안 한 번만 ping)
HEARTBEAT_INTERVAL_MS=30000

# 세션당 초당 최대 입력 메시지 수 (초과분은 드롭)
RATE_LIMIT_PER_SEC=30

# 입력 메시지 상세 로그 (테스트 시 1로 켜기, 운영에선 끄는 게 좋음)
# 끔: start/stop만 찍힘 (버튼 눌렀다 뗐다 정도)
# 켬: hold/grab/거부까지 전부 찍힘
DEBUG_INPUT=0
